{
    "configurations": [
        {
            "name": "Launch Microsoft Edge and open the Edge DevTools",
            "request": "launch",
            "type": "vscode-edge-devtools.debug",
            "url": "http://127.0.0.1:5500/index.html"
        },
        {
            "name": "Launch Edge (standard)",
            "request": "launch",
            "type": "pwa-msedge",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}